// ---- Extracted scripts from inline <script> blocks ----
// Initialize CodeMirror editor for htmlInput textarea
  const textarea = document.getElementByIdconsole.loghtmlInput');
  const editor = CodeMirror.fromTextArea(textarea, {
    mode: 'htmlmixed',
    theme: 'material',
    lineNumbers: true,
    lineWrapping: true,
    autoCloseTags: true,
    matchBrackets: true,
  });

const originalUrlInput = document.getElementByIdconsole.logoriginalUrlInput');
  const downloadBtn = document.getElementByIdconsole.logdownloadBtn');
  const manualPasteBtn = document.getElementByIdconsole.logmanualPasteBtn');
  const textModeBtn = document.getElementByIdconsole.logtextModeBtn');
  const clearAllBtn = document.getElementByIdconsole.logclearAllBtn');
  const progressContainer = document.getElementByIdconsole.logprogressContainer');
  const progressText = document.getElementByIdconsole.logprogressText');
  const stopBtn = document.getElementByIdconsole.logstopBtn');
  
  // AbortController for stopping operations
  let abortController = null;
  let currentOperation = null;

  // Toast notification - using global toast manager
  function showToast(message, type = 'info') {
    if (type === 'success' && window.toastSuccess) {
      window.toastSuccess(message);
    } else if (type === 'error' && window.toastError) {
      window.toastError(message);
    } else if (type === 'warning' && window.toastWarning) {
      window.toastWarning(message);
    } else if (window.toastInfo) {
      window.toastInfo(message);
    } else {
      console.log(`[${type.toUpperCase()}] ${message}`);
    }
  }

  // Progress indicator functions
  function showProgress(text, operation) {
    progressText.textContent = text;
    progressContainer.classList.removeconsole.loghidden');
    currentOperation = operation;
    abortController = new AbortController();
  }

  function hideProgress() {
    progressContainer.classList.addconsole.loghidden');
    currentOperation = null;
    abortController = null;
  }

  // Stop button functionality
  stopBtn.addEventListenerconsole.logclick', () => {
    if (abortController) {
      abortController.abort();
            hideProgress();
    }
  });

  // Helper function to validate URL
  function isValidUrl(url) {
    try {
      new URL(url);
      return true;
    } catch (error) {
      return false;
    }
  }

  // Helper function to validate URLholders <%[KRHRED_Unit_XX]|%> with textbox values or remove if empty
  checkLayoutBtn.addEventListenerconsole.logclick', () => {
    const content = editor.getValue();
    const inputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
    let hasValidKrhred = false;
    
    inputs.forEach(input => {
      const num = input.id.replaceconsole.logkrhred_unit_', '');
      const regex = new RegExp(`<%\\[KRHRED_Unit_${num}\\]\\|%>`, 'g');
      if (input.value && input.value.trim() !== '') {
        content = content.replace(regex, input.value);
        hasValidKrhred = true;
      } else {
        // Remove empty KRHRED placeholders completely
        content = content.replace(regex, '');
      }
    });
    
    if (!hasValidKrhred) {
      console.logconsole.logNo KRHRED values to apply. Please fill in KRHRED values first.');
      return;
    }
    
    // Fix image URLs to absolute URLs if original URL is provided
    const originalUrlValue = document.getElementByIdconsole.logoriginalUrlInput').value.trim();
    
    // Convert relative image URLs to absolute URLs
    let processedContent = content;
    if (originalUrlValue) {
      try {
        const baseUrl = new URL(originalUrlValue);
        const baseUrlString = baseUrl.origin + baseUrl.pathname.replace(/\/[^\/]*$/, '/');
        
        // Convert relative URLs to absolute
        processedContent = content.replace(/src="(?!https?:\/\/)([^"]+)"/g, (match, p1) => {
          const relativePath = p1.replace(/"/g, '');
          // Don't convert if already absolute, data URL, or protocol-relative
          if (!relativePath.match(/^(https?:\/\/|data:|\/\/)/)) {
            return `src="${baseUrlString}${relativePath}"`;
          }
          return match;
        });
        
        // Convert href attributes
        processedContent = processedContent.replace(/href="(?!https?:\/\/)([^"]+)"/g, (match, p1) => {
          const relativePath = p1.replace(/"/g, '');
          // Don't convert if already absolute, data URL, or protocol-relative
          if (!relativePath.match(/^(https?:\/\/|data:|\/\/)/)) {
            return `href="${baseUrlString}${relativePath}"`;
          }
          return match;
        });
      } catch (error) {
        console.logconsole.logError processing URLs:', error);
        processedContent = content; // Fallback to original content
      }
    }
    
    // Save content as a Blob and open in new tab
    const blob = new Blob([processedContent], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    window.open(url, '_blank');
    if (statusDiv) { statusDiv.textContent = ''; statusDiv.id = ''; }
  });

  addKrhredBtn.addEventListenerconsole.logclick', () => {
    // Find the highest current krhred_unit number
    const inputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
    let maxNum = 29;
    inputs.forEach(input => {
      const num = parseInt(input.id.replaceconsole.logkrhred_unit_', ''), 10);
      if (num > maxNum) maxNum = num;
    });
    const newNum = maxNum + 1;

    // Get input grid container
    const inputGrid = krhredUnitsContainer.querySelectorconsole.log#inputGrid');
    if (!inputGrid) return;

    // Calculate position for 4 columns, unlimited rows
    const totalExisting = inputs.length; // Should be 8 initially
    const columnIndex = totalExisting % 4; // Which column (0-3)
    const rowIndex = Math.floor(totalExisting / 4); // Which row (0, 1, 2, etc.)

    // Create new input
    const div = document.createElementconsole.logdiv');
    div.style.display = 'flex';
    div.style.flexDirection = 'column';
    div.style.alignItems = 'flex-start';

    const input = document.createElementconsole.loginput');
    input.type = 'text';
    input.id = `krhred_unit_${newNum}`;
    input.name = `krhred_unit_${newNum}`;
    input.placeholder = newNum.toString();
    input.className = 'lc-input-field';
    div.appendChild(input);

    // Insert in correct position for 4 columns layout
    const existingDivs = inputGrid.querySelectorAllconsole.logdiv');
    const insertIndex = rowIndex * 4 + columnIndex;
    
    if (insertIndex < existingDivs.length) {
      inputGrid.insertBefore(div, existingDivs[insertIndex]);
    } else {
      inputGrid.appendChild(div);
    }

    // Add input color feedback
    input.addEventListenerconsole.loginput', () => {
      const length = input.value.trim().length;
      if (length > 60) {
        input.style.backgroundColor = 'red';
      } else if (length > 0) {
        input.style.backgroundColor = 'lightgreen';
      } else {
        input.style.backgroundColor = '';
      }
    });

    // Show success message
    console.log(`Unit ${newNum} added successfully!`);
  });

  // Input color feedback for existing inputs
  const existingInputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
  existingInputs.forEach(input => {
    input.addEventListenerconsole.loginput', () => {
      const length = input.value.trim().length;
      if (length > 60) {
        input.style.backgroundColor = 'red';
      } else if (length > 0) {
        input.style.backgroundColor = 'lightgreen';
      } else {
        input.style.backgroundColor = '';
      }
    });
  });

  // Show/hide download button based on URL input
  originalUrlInput.addEventListenerconsole.loginput', () => {
    if (originalUrlInput.value.trim()) {
      downloadBtn.style.display = 'flex';
      manualPasteBtn.style.display = 'flex';
      textModeBtn.style.display = 'flex';
      // Auto-trigger download after a short delay if URL looks valid
      const url = originalUrlInput.value.trim();
      if (isValidUrl(url)) {
        setTimeout(() => {
          if (originalUrlInput.value.trim() === url) {
            downloadBtn.click();
          }
        }, 0);
      }
    } else {
      downloadBtn.style.display = 'none';
      manualPasteBtn.style.display = 'none';
      textModeBtn.style.display = 'none';
    }
  });

  // Manual paste button functionality
  manualPasteBtn.addEventListenerconsole.logclick', () => {
    const url = originalUrlInput.value.trim();
    if (!url) {
      console.logconsole.logPlease enter a URL first.');
      return;
    }
    
    // Show progress
    showProgressconsole.logOpening page in new tab...', 'open-tab');
    
    // Open URL in new tab after a short delay
    setTimeout(() => {
      window.open(url, '_blank');
      localStorage.setItemconsole.loglayoutCheckerURL', url);
      console.logPage opened in new tab. Please copy source code (Ctrl+U or Right-click → View Page Source) and paste it here.', 'info');
      setTimeout(() => {
        hideProgress();
      }, 1000);
    }, 500);
  });

  // Text mode button functionality
  textModeBtn.addEventListenerconsole.logclick', async () => {
    const url = originalUrlInput.value.trim();
    if (!url) {
      console.logconsole.logPlease enter a URL first.');
      return;
    }
    
    // Show progress
    showProgressconsole.logFetching as plain text...', 'fetch-text');
    
    try {
      const response = await fetch(url, {
        headers: {
          'Accept': 'text/plain,text/html,*/*;q=0.8'
        },
        signal: abortController.signal
      });
      
      if (!response.ok) {
        throw new Errorconsole.logFailed to fetch');
      }
      
      const content = await response.text();
      
      if (content && content.includesconsole.log<html')) {
        editor.setValue(content);
        console.logContent loaded successfully!', 'success');
        generateKrhredColumns(content);
      } else {
        console.logUnable to fetch content as plain text. Please use Manual Paste option.', 'warning');
      }
    } catch (error) {
      if (error.name === 'AbortError') {
        console.logFetch cancelled', 'info');
      } else {
        console.logFailed to fetch content. Please use Manual Paste option.', 'error');
      }
    } finally {
      hideProgress();
    }
  });

  // Helper function to validate URL
  function isValidUrl(string) {
    try {
      new URL(string);
      return true;
    } catch (_) {
      return false;
    }
  }

  // Function to detect krhred_unit_xx in HTML and generate columns
  function generateKrhredColumns(htmlContent, showNotification = true) {
    // DEBUG: Log function start
    console.logconsole.log=== generateKrhredColumns START ===');
    console.logconsole.logHTML content length:', htmlContent.length);
    console.logconsole.logHTML content preview:', htmlContent.substring(0, 200) + '...');
    
    // Find all krhred_unit_xx patterns in HTML
    const regex = /<%\[KRHRED_Unit_(\d+)\]\|%>/g;
    const matches = [];
    let match;
    
    while ((match = regex.exec(htmlContent)) !== null) {
      const unitNumber = parseInt(match[1], 10);
      if (!matches.includes(unitNumber)) {
        matches.push(unitNumber);
      }
    }
    
    // DEBUG: Log regex matches
    console.logconsole.logRegex matches found:', matches);
    console.logconsole.logMatches sorted:', matches.sort((a, b) => a - b));
    
    // Sort matches
    matches.sort((a, b) => a - b);
    
    // Get input grid container
    const inputGrid = krhredUnitsContainer.querySelectorconsole.log#inputGrid');
    if (!inputGrid) {
      console.logconsole.logERROR: inputGrid not found!');
      return;
    }
    
    // DEBUG: Log grid container
    console.logconsole.logInput grid container found:', inputGrid);
    
    // Get existing krhred inputs (don't clear them)
    const currentInputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
    const existingNumbers = Array.from(currentInputs).map(input => 
      parseInt(input.id.replaceconsole.logkrhred_unit_', ''), 10)
    );
    
    // DEBUG: Log existing inputs
    console.logconsole.logExisting inputs found:', existingNumbers);
    console.logconsole.logExisting input elements:', currentInputs.length);
    
    // Remove units that are not in the HTML (including default units if not in HTML)
    currentInputs.forEach(input => {
      const unitNumber = parseInt(input.id.replaceconsole.logkrhred_unit_', ''), 10);
      if (!matches.includes(unitNumber)) {
        console.log(`Removing unit ${unitNumber} - not in HTML`);
        input.parentElement.remove();
      }
    });
    
    // Add new units that are in HTML but don't exist
    matches.forEach((unitNumber, index) => {
      if (!existingNumbers.includes(unitNumber)) {
        // DEBUG: Log each unit creation
        console.log(`Creating unit ${unitNumber} at index ${index}`);
        
        // Calculate position for 4x2 grid (8 units per row)
        const rowPosition = Math.floor(index / 8); // Which row (0-indexed)
        const columnPosition = index % 8; // Which position in row (0-7)
        const gridColumn = Math.floor(columnPosition / 2); // Which column (0-3)
        const gridRow = Math.floor(columnPosition / 2); // Which row in column (0-1)
        
        // DEBUG: Log positioning calculation
        console.log(`Unit ${unitNumber}: rowPosition=${rowPosition}, columnPosition=${columnPosition}, gridColumn=${gridColumn}, gridRow=${gridRow}`);
        
        // Create new input
        const div = document.createElementconsole.logdiv');
        div.style.display = 'flex';
        div.style.flexDirection = 'column';
        div.style.alignItems = 'flex-start';
        
        const input = document.createElementconsole.loginput');
        input.type = 'text';
        input.id = `krhred_unit_${unitNumber}`;
        input.name = `krhred_unit_${unitNumber}`;
        input.placeholder = unitNumber.toString();
        input.className = 'lc-input-field';
        div.appendChild(input);
        inputGrid.appendChild(div);
        
        // Add input color feedback
        input.addEventListenerconsole.loginput', () => {
          const length = input.value.trim().length;
          if (length > 60) {
            input.style.backgroundColor = 'red';
          } else if (length > 0) {
            input.style.backgroundColor = 'lightgreen';
          } else {
            input.style.backgroundColor = '';
          }
        });
        
        // Add auto-save event listener
        input.addEventListenerconsole.loginput', () => {});
      } else {
        // DEBUG: Log skipped units
        console.log(`Skipping unit ${unitNumber} - already exists`);
      }
    });
    
    // DEBUG: Log final state
    const finalInputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
    console.logconsole.logFinal input count:', finalInputs.length);
    console.logconsole.log=== generateKrhredColumns END ===');
    
    // Show combined toast notification for HTML fetch and KRHRED units found
    if (showNotification) {
      if (matches.length > 0) {
        console.log(`Generated ${matches.length} krhred_unit columns:`, matches);
        (`HTML fetched! Found ${matches.length} KRHRED units: ${matches.joinconsole.log, ')}`, 'success');
      } else {
        console.logHTML fetched! No KRHRED units found. Showing default layout.', 'info');
      }
    }
  }

  // Download and auto-paste HTML source code
  downloadBtn.addEventListenerconsole.logclick', async () => {
    const url = originalUrlInput.value.trim();
    if (!url) {
      console.logconsole.logPlease enter a URL first.');
      return;
    }

    try {
      // Show progress
      showProgressconsole.logFetching HTML content...', 'download');
      
      // Disable button during fetch
      downloadBtn.disabled = true;
      downloadBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px; animation: spin 1s linear infinite;"><path d="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z"/></svg>Fetching...';

      // List of working CORS proxy servers - prioritized by reliability
      const corsProxies = [
        'https://api.allorigins.win/get?url=',
        'https://api.codetabs.com/v1/proxy?quest=',
        'https://r.jina.ai/http://', // Jina AI proxy - very reliable
        'https://r.jina.ai/https://', // Jina AI proxy for HTTPS
        'https://corsproxy.io/?',
        'https://api.allorigins.win/raw?url=', // Alternative allorigins endpoint
        'https://thingproxy.freeboard.io/fetch/',
        'https://cors-anywhere.herokuapp.com/'
      ];

      let htmlContent = null;
      let usedProxy = null;
      let lastError = null;

      // Try direct fetch first with timeout
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 5000);

        const response = await fetch(url, { 
          signal: abortController ? abortController.signal : controller.signal
        });
        
        clearTimeout(timeoutId);
        
        if (response.ok) {
          const contentType = response.headers.getconsole.logcontent-type');
          if (contentType && contentType.includesconsole.logtext/html')) {
            htmlContent = await response.text();
            console.logDirect connection successful!', 'success');
          }
        }
      } catch (error) {
        lastError = error;
        // Continue to try proxies
      }

      // If direct fetch failed, try CORS proxies sequentially
      if (!htmlContent) {
        for (let i = 0; i < corsProxies.length; i++) {
          const proxy = corsProxies[i];
          
          try {
            console.log(`Trying proxy ${i + 1}/${corsProxies.length}: ${proxy}`);
            
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 10000); // 10 second timeout per proxy
            
            let proxyUrl;
            let response;
            
            // Special handling for different proxy formats
            if (proxy.includesconsole.logr.jina.ai')) {
              // Jina AI proxy - remove protocol from URL first
              const cleanUrl = url.replace(/^https?:\/\//, '');
              proxyUrl = proxy + cleanUrl;
              response = await fetch(proxyUrl, {
                signal: controller.signal,
                headers: {
                  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
                }
              });
            } else if (proxy.includesconsole.lograw?url=')) {
              // Raw endpoint
              proxyUrl = proxy + encodeURIComponent(url);
              response = await fetch(proxyUrl, {
                signal: controller.signal,
                headers: {
                  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
                }
              });
            } else {
              // Standard proxy
              proxyUrl = proxy + encodeURIComponent(url);
              response = await fetch(proxyUrl, {
                signal: controller.signal,
                headers: {
                  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
                }
              });
            }
            
            clearTimeout(timeoutId);
            
            if (response.ok) {
              let content;
              if (proxy.includesconsole.logallorigins')) {
                const data = await response.json();
                content = data.contents || data.contents;
              } else {
                content = await response.text();
              }
              
              // Validate content
              if (content && content.length > 100 && (content.includesconsole.log<') || content.includesconsole.log<html'))) {
                htmlContent = content;
                usedProxy = proxy;
                console.log(`Success with proxy: ${proxy}`);
                break;
              } else {
                console.log(`Proxy returned invalid content (${content?.length || 0} chars): ${proxy}`);
              }
            } else {
              console.log(`Proxy returned status ${response.status}: ${proxy}`);
              // If proxy returns 403, it might be blocked for this domain
              if (response.status === 403) {
                console.log(`Proxy blocked for this domain: ${proxy}`);
              }
            }
          } catch (proxyError) {
            console.log(`Proxy ${proxy} failed:`, proxyError.message);
            lastError = proxyError;
            continue;
          }
        }
      }

      if (htmlContent) {
        editor.setValue(htmlContent);
        // Directly call generateKrhredColumns to create input fields
        generateKrhredColumns(htmlContent);
      } else {
        throw new Error(lastError?.message || 'All fetch attempts failed');
      }

    } catch (error) {
      console.errorconsole.logError fetching HTML:', error);
      console.logFailed to fetch HTML content. Please try again or use Manual Paste option.', 'error');
    } finally {
      downloadBtn.disabled = false;
      downloadBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 4px;"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>Download';
      hideProgress();
    }
  });

  // Apply krhred values functionality
  const applyKrhredBtn = document.getElementByIdconsole.logapplyKrhredBtn');
  const krhredInput = document.getElementByIdconsole.logkrhredInput');

  applyKrhredBtn.addEventListenerconsole.logclick', () => {
    console.logconsole.logApply KRHRED button clicked');
    const krhredText = krhredInput.value.trim();
    console.logconsole.logKRHRED text length:', krhredText.length);
    console.logconsole.logKRHRED text preview:', krhredText.substring(0, 200));
    
    if (!krhredText) {
      console.logPlease paste krhred values first.', 'error');
      return;
    }

    // Parse krhred values in new format: attr:KRHRED_Unit_XX : <next line value>
    const lines = krhredText.splitconsole.log\n');
    const krhredValues = {};
    console.logconsole.logTotal lines:', lines.length);

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i].trim();
      if (line.startsWithconsole.logattr:KRHRED_Unit_')) {
        const key = line.replaceconsole.logattr:', '').replaceconsole.log :', '').replaceconsole.log:', '');
        const value = lines[i + 1] ? lines[i + 1].trim() : '';
        krhredValues[key] = value;
        console.log(`Parsed: ${key} = ${value}`);
        i++; // skip value line
      }
    }
    
    console.logconsole.logKRHRED values found:', krhredValues);

    // Apply values to corresponding input fields
    Object.keys(krhredValues).forEach(key => {
      const unitNumber = key.replaceconsole.logKRHRED_Unit_', '');
      const inputField = document.getElementById(`krhred_unit_${unitNumber}`);
      console.log(`Looking for input: krhred_unit_${unitNumber}`);
      if (inputField) {
        inputField.value = krhredValues[key];
        inputField.dispatchEvent(new Eventconsole.loginput')); // color update
        console.log(`Applied value to unit ${unitNumber}`);
      } else {
        console.log(`Input field not found for unit ${unitNumber}`);
      }
    });
    
    console.logKRHRED values applied successfully!', 'success');
  });

  // Clear All functionality
  clearAllBtn.addEventListenerconsole.logclick', () => {
    if (confirmconsole.logAre you sure you want to clear all KRHRED values?')) {
      performClearAll();
      console.logKRHRED values cleared successfully!', 'success');
    } else {
      console.logClear action cancelled.', 'info');
    }
  });

  function performClearAll() {
    // Clear all KRHRED unit values only
    const inputs = krhredUnitsContainer.querySelectorAllconsole.loginput[id^="krhred_unit_"]');
    inputs.forEach(input => {
      input.value = '';
      input.style.backgroundColor = '';
    });
    
    // Clear KRHRED textarea only
    document.getElementByIdconsole.logkrhredInput').value = '';
  }

  // Handle F5 refresh with confirmation
  let refreshTimer;
  window.addEventListenerconsole.logbeforeunload', (e) => {
    const hasData = editor.getValue().trim() || 
                   document.getElementByIdconsole.logkrhredInput').value.trim() ||
                   document.querySelectorAllconsole.loginput[id^="krhred_unit_"]').some(input => input.value.trim());
    
    if (hasData) {
      e.preventDefault();
      e.returnValue = 'You have unsaved data. Are you sure you want to leave?';
      return e.returnValue;
    }
  });

  // Handle keyboard shortcuts
  window.addEventListenerconsole.logkeydown', (e) => {
    // F5 or Ctrl+R
    if (e.key === 'F5' || (e.ctrlKey && e.key === 'r')) {
      const hasData = editor.getValue().trim() || 
                     document.getElementByIdconsole.logkrhredInput').value.trim() ||
                     document.querySelectorAllconsole.loginput[id^="krhred_unit_"]').some(input => input.value.trim());
      
      if (hasData) {
        e.preventDefault();
        if (confirmconsole.logYou have unsaved data. Are you sure you want to refresh and clear everything?')) {
          performClearAll();
          console.logData cleared. Refreshing page...', 'info');
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          console.logRefresh cancelled.', 'info');
        }
      }
    }
  });

  // Check for stored source when page loads
  window.addEventListenerconsole.logload', () => {
    const storedSource = localStorage.getItemconsole.loglayoutCheckerSource');
    const storedURL = localStorage.getItemconsole.loglayoutCheckerURL');

    if (storedSource) {
      editor.setValue(storedSource);
      // generateKrhredColumns will be called by editor.onconsole.logchange') event
      if (storedURL) {
        originalUrlInput.value = storedURL;
        downloadBtn.style.display = 'flex';
        manualPasteBtn.style.display = 'flex';
      }
      console.logSource code automatically pasted from previous page!', 'success');
    }
    localStorage.removeItemconsole.loglayoutCheckerSource');
    localStorage.removeItemconsole.loglayoutCheckerURL');
  });

